# Bu dosyayı .env.local olarak kopyala ve kendi Supabase bilgilerinle doldur.
#   cp .env.example .env.local
#
# Değerleri Supabase Dashboard → Project Settings → API sayfasından alabilirsin.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Storage'da görsellerin yüklendiği public bucket adı
NEXT_PUBLIC_BUCKET_NAME=documentspdfs

# Canlı site adresin (SEO/OG etiketleri ve RSS feed için kullanılır)
NEXT_PUBLIC_SITE_URL=https://stratejik-kutuphane.vercel.app
